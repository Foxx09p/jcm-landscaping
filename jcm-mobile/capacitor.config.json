{
  "appId": "com.jcmlandscaping.app",
  "appName": "JCM Landscaping",
  "webDir": "www",
  "bundledWebRuntime": false,
  "server": {
    "androidScheme": "https"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "launchAutoHide": true,
      "backgroundColor": "#0f3d1f",
      "androidSplashResourceName": "splash",
      "androidScaleType": "CENTER_CROP",
      "showSpinner": false
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#0f3d1f"
    },
    "GoogleAuth": {
      "scopes": ["profile", "email"],
      "serverClientId": "419377251087-REPLACE_WITH_OAUTH_CLIENT_ID.apps.googleusercontent.com",
      "forceCodeForRefreshToken": true
    }
  }
}
